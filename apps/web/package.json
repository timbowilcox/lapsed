{
  "name": "@lapsed/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "sync-env": "node scripts/sync-env.mjs",
    "dev": "pnpm sync-env && next dev --port 3000",
    "build": "pnpm sync-env && next build",
    "start": "pnpm sync-env && next start --port 3000",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "pnpm sync-env && playwright test",
    "test:a11y": "pnpm sync-env && playwright test e2e/a11y.spec.ts",
    "clean": "rm -rf .turbo .next node_modules/.cache"
  },
  "dependencies": {
    "@lapsed/core": "workspace:*",
    "@lapsed/db": "workspace:*",
    "@lapsed/fixtures": "workspace:*",
    "@lapsed/shopify": "workspace:*",
    "@lapsed/ui": "workspace:*",
    "@shopify/app-bridge-react": "^4.1.6",
    "lucide-react": "^0.468.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.13.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@lapsed/config": "workspace:*",
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.1.0",
    "pg": "^8.13.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0",
    "vitest": "^2.1.8"
  }
}
