{
  "name": "lapsed-ai",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "test:a11y": "pnpm --filter @lapsed/web test:a11y",
    "storybook": "turbo run storybook --filter=@lapsed/storybook",
    "db:push": "pnpm --filter @lapsed/db db:push",
    "db:types": "pnpm --filter @lapsed/db db:types",
    "db:diagnose": "node scripts/db-diagnose.mjs",
    "grep:pii": "node scripts/grep-pii.mjs",
    "grep:format-check": "node scripts/grep-format-check.mjs",
    "vercel:env:check": "node scripts/vercel-env-check.mjs",
    "vercel:env:push": "node scripts/push-vercel-env.mjs",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "postgres": "^3.4.9",
    "prettier": "^3.4.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}